<?xml version="1.0" encoding="UTF-8"?>
<Context>
  <Resource
    name="jdbc/sanhak"
    auth="Container"
    type="javax.sql.DataSource"
    driverClassName="com.mysql.jdbc.Driver"
    url="jdbc:mysql://localhost:3306/sanhak?useSSL=false"
    username="root"
    password="1234"
    maxTotal="20"
    maxIdle="10"
    minIdle="2"
    maxWaitMillis="5000"
    validationQuery="SELECT 1"
    testOnBorrow="true"
    testWhileIdle="true"
  />
</Context>
